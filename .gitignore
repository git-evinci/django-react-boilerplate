frontend/.env.development.local
frontend/.env.test.local
frontend/.env.production.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Logs & Runtime ---
logs/*.log
*.log
backend/access.log
backend/error.log

